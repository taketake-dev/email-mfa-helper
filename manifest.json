{
  "manifest_version": 3,
  "name": "Email MFA Helper",
  "version": "1.0.1",
  "description": "RD講義資料ページのメール認証コード入力を補助します。",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://lms.rd.dendai.ac.jp/admin/tool/mfa/auth.php*"],
      "js": ["src/moodle.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://outlook.office.com/mail/*",
        "https://outlook.cloud.microsoft/mail/*"
      ],
      "js": ["src/config.js", "src/outlook-logic.js", "src/outlook.js"],
      "run_at": "document_idle"
    }
  ]
}
